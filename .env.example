# Copy to `.env.development` or `.env.production` as needed.
# Public values only — never put secrets in Vite env (they are embedded in the bundle).

# Logos HTTP API base URL (no trailing slash). Required for production builds.
# Default in dev: http://localhost:8000 (Logos default API_PORT) if unset.
# VITE_LOGOS_API_BASE_URL=http://localhost:8000
